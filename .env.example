# Copy this file to .env and fill in your values

# Backend API base URL
VITE_API_BASE_URL=
VITE_PAYSTACK_PUBLIC_KEY=
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CAMPUS_HINT=
VITE_GEOAPIFY_KEY=
VITE_WHATSAPP_NUMBER=

# Firebase Cloud Messaging (push notifications)
# Find these in Firebase Console → Project settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
# Firebase App ID (e.g. 1:123456789:web:abc123...)
VITE_FIREBASE_APP_ID=
# Sender ID from Firebase Console → Project settings → Cloud Messaging
VITE_FIREBASE_MESSAGING_SENDER_ID=
# Firebase project ID (e.g. chop-spot-12345)
VITE_FIREBASE_PROJECT_ID=
# VAPID key from Firebase Console → Project settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=
